<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bài trắc nghiệm</title>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --success: #22c55e;
            --success-bg: #dcfce7;
            --error: #ef4444;
            --error-bg: #fee2e2;
            --border: #e2e8f0;
        }
        
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            line-height: 1.5;
            display: flex;
            justify-content: center;
            padding: 2rem 1rem;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 800px;
        }

        .card {
            background-color: var(--card-bg);
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            padding: 2rem;
            margin-bottom: 2rem;
        }

        .header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .title {
            font-size: 1.875rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .progress-text {
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .progress-bar-container {
            width: 100%;
            background-color: var(--border);
            height: 0.5rem;
            border-radius: 9999px;
            overflow: hidden;
            margin-bottom: 2rem;
        }

        .progress-bar {
            height: 100%;
            background-color: var(--primary);
            transition: width 0.3s ease;
        }

        .question-text {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .question-image {
            max-width: 100%;
            border-radius: 0.5rem;
            margin-bottom: 1.5rem;
            max-height: 300px;
            object-fit: contain;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }

        .options-grid {
            display: grid;
            gap: 1rem;
        }

        .option-btn {
            width: 100%;
            text-align: left;
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
            border: 2px solid var(--border);
            background-color: var(--card-bg);
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-main);
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .option-image {
            max-width: 100%;
            border-radius: 0.25rem;
            max-height: 150px;
            object-fit: contain;
        }

        .option-btn:hover:not(:disabled) {
            border-color: var(--primary);
            background-color: #f1f5f9;
        }

        .option-btn.correct {
            border-color: var(--success);
            background-color: var(--success-bg);
            color: #166534;
        }

        .option-btn.incorrect {
            border-color: var(--error);
            background-color: var(--error-bg);
            color: #991b1b;
        }

        .option-btn:disabled {
            cursor: default;
        }

        .next-btn {
            display: block;
            width: 100%;
            padding: 1rem;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 0.75rem;
            font-size: 1.125rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 2rem;
            transition: background-color 0.2s ease;
        }

        .next-btn:hover {
            background-color: var(--primary-hover);
        }

        .results-container {
            text-align: center;
        }

        .score-circle {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background-color: #e0e7ff;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem auto;
            border: 8px solid var(--primary);
        }

        .score-text {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary);
        }

        .results-message {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .results-subtext {
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .restart-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.75rem 1.5rem;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 0.5rem;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease;
        }

        .restart-btn:hover {
            background-color: var(--primary-hover);
        }

        .feedback-message {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 1.125rem;
            font-weight: 600;
            padding: 0.75rem;
            border-radius: 0.5rem;
            animation: fadeIn 0.3s ease;
        }

        .feedback-correct {
            background-color: var(--success-bg);
            color: #166534;
            border: 2px solid var(--success);
        }

        .feedback-incorrect {
            background-color: var(--error-bg);
            color: #991b1b;
            border: 2px solid var(--error);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1 class="title" id="quiz-title"></h1>
        </div>

        <div id="quiz-container" class="card">
            <div class="progress-text">
                Câu hỏi <span id="current-q-num">1</span> / <span id="total-q-num"></span>
            </div>
            <div class="progress-bar-container">
                <div id="progress-bar" class="progress-bar" style="width: 0%"></div>
            </div>

            <h2 id="question-text" class="question-text"></h2>
            <img id="question-image" class="question-image hidden" src="" alt="Question image">
            
            <div id="options-container" class="options-grid">
                <!-- Options will be generated here -->
            </div>

            <div id="feedback-message" class="feedback-message hidden"></div>

            <button id="next-btn" class="next-btn hidden">Tiếp tục</button>
        </div>

        <div id="results-container" class="card hidden results-container">
            <h2 class="results-message">Hoàn thành bài kiểm tra!</h2>
            <div class="score-circle">
                <div class="score-text"><span id="score-val">0</span>/<span id="score-total">0</span></div>
            </div>
            <p class="results-subtext" id="results-feedback"></p>
            <button id="restart-btn" class="restart-btn">Làm lại bài kiểm tra</button>
        </div>
    </div>

    <!-- Canvas for Confetti -->
    <canvas id="confetti-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9999;"></canvas>

    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        const quizData = {"title":"Bài trắc nghiệm","questions":[{"id":"5618aa9b-3d8d-4597-b47e-952ef1894252","text":"Đâu là biểu tượng phần mềm WordPad?","image":"","answers":[{"id":"84ee31e7-687e-4189-a838-dd26752e93e7","text":"","isCorrect":true,"image":"data:image/png;base64,"},{"id":"47ebb794-7a81-4527-ac2e-1d199e2aa867","text":"","isCorrect":false,"image":"data:image/png;base64,"},{"id":"dc579cc8-a696-4a8c-9697-60d935644376","text":"","isCorrect":false,"image":"data:image/png;base64,"}]},{"id":"095980f8-4301-4ff3-8d17-93a534dceb85","text":"Phần mềm WordPad dùng để làm gì?","image":"data:image/png;base64,","answers":[{"id":"9ea5c18d-c063-49be-9b30-539495b37cca","text":"Dùng để học Toán","isCorrect":false},{"id":"4a207ff4-0ae8-45e3-95a7-af1add01473f","text":"Dùng để học Tiếng Anh","isCorrect":false},{"id":"96794512-078f-44f7-8063-9ddac33b367f","text":"Dùng ghi chép nội dung","isCorrect":true}]},{"id":"60c34724-d563-42a3-b9ed-38c2e632bb8b","text":"Công cụ dưới đây có chức năng gì?","image":"data:image/png;base64,","answers":[{"id":"38127229-96cf-496d-a82b-c78beba177e3","text":"Làm chữ in nghiêng","isCorrect":false},{"id":"9d758ad9-6861-4d4c-8369-b71b012bbc87","text":"Làm chữ gạch chân","isCorrect":false},{"id":"018374f7-1da0-4930-879f-fb4d39753737","text":"Làm chữ in đậm","isCorrect":true}]},{"id":"44970166-1b4a-433c-825f-25c666099df8","text":"Công cụ bên dưới dùng để làm gì?","image":"data:image/png;base64,","answers":[{"id":"39b3adb3-b9db-457d-bb54-abb44bd80fd6","text":"Thay đổi kiểu chữ","isCorrect":false},{"id":"b209f53a-6e6c-4cd2-b28d-e9111b8f1da9","text":"Làm chữ in nghiêng","isCorrect":true},{"id":"40e6e804-5c3c-4ec7-acbc-3a39136d2c99","text":"Làm chữ gạch chân","isCorrect":false}]},{"id":"1652dc91-95eb-4a17-a7e4-87cc71d63e7c","text":"Công cụ nào dưới đây giúp gạch chân chữ?","image":"","answers":[{"id":"7bd0b0de-4509-44b9-bdd3-b3d8254cee69","text":"","isCorrect":false,"image":"data:image/png;base64,"},{"id":"b9fb5a66-4452-4584-9828-b6d67e50183f","text":"","isCorrect":false,"image":"data:image/png;base64,"},{"id":"73e30762-278e-4ea9-8306-a744f200939a","text":"","isCorrect":true,"image":"data:image/png;base64,"}]},{"id":"cf3efa1c-7a60-4a13-aecf-d72aaadd399f","text":"Công cụ này có chức năng gì?","image":"data:image/png;base64,","answers":[{"id":"ac413437-a7db-4973-9eb4-7fa631b03a9b","text":"Thay đổi kiểu chữ","isCorrect":true},{"id":"9accf12f-72eb-45af-baac-bca954d18b36","text":"Thay đổi màu sắc","isCorrect":false},{"id":"ba9861b0-1f85-49c1-9aa4-dee992f17499","text":"Thay đổi kích thước chữ","isCorrect":false}]},{"id":"299856e4-d346-4128-8bd5-4bf27b73fae0","text":"Trong phần mềm WordPad phím này có chức năng gì","image":"data:image/png;base64,","answers":[{"id":"c79300ca-61be-488e-b7e9-014ada08d739","text":"Xóa 1 ký tự","isCorrect":false},{"id":"eff481cb-5d7a-4880-984f-5a5907b068ce","text":"Xuống dòng","isCorrect":true},{"id":"7c5af725-3e6d-4557-9353-af3604483f94","text":"Viết hoa 1 ký tự","isCorrect":false}]},{"id":"51c7857e-b535-4fbb-99d3-0f192bad3132","text":"Phím này có chức năng gì?","image":"data:image/png;base64,","answers":[{"id":"966b33d2-9f2b-4651-9eb0-366d110d678d","text":"Thục đầu dòng","isCorrect":true},{"id":"886045fc-f2d8-45fb-b181-eda86a26073e","text":"Viết hoa ký tự đầu","isCorrect":false},{"id":"4ff4dabc-7a91-4895-abcf-1abfbd1f8bef","text":"Xóa 1 ký tự","isCorrect":false}]},{"id":"7bb414c0-4913-44b9-a2e9-7d5d67ab658e","text":"Phím nào dưới đây dùng để xóa 1 ký tự?","image":"","answers":[{"id":"7620f02b-277f-4fd0-ba59-297f17da85e3","text":"","isCorrect":false,"image":"data:image/png;base64,"},{"id":"711c8560-664b-4cc3-996b-9ab5dc067bf4","text":"","isCorrect":false,"image":"data:image/png;base64,"},{"id":"d26aca7e-af81-4219-90ac-7623de0f4ae2","text":"","isCorrect":true,"image":"data:image/png;base64,"}]},{"id":"dc030954-a428-446a-89ea-f9af4c5700c1","text":"Phím này dùng để làm gì?","image":"data:image/png;base64,","answers":[{"id":"55ceef5d-b355-4609-b6b9-9cd58d42dcda","text":"Tạo khoảng cách","isCorrect":false},{"id":"5f772f82-600c-4b6e-a078-a1ee84dfdf8c","text":"Viết hoa chữ cái","isCorrect":true},{"id":"9a303d8e-8299-4a3c-897c-708c5f0c245b","text":"Xuống dòng","isCorrect":false}]}],"settings":{"shuffleQuestions":false,"shuffleAnswers":false}};
        
        // Audio
        const correctSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2000/2000-preview.mp3');
        const incorrectSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2954/2954-preview.mp3');
        const victorySound = new Audio('https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3');

        // State
        let currentQuestionIndex = 0;
        let score = 0;
        let isAnswered = false;
        let hasAttempted = false;
        let questions = [];

        // DOM Elements
        const titleEl = document.getElementById('quiz-title');
        const quizContainer = document.getElementById('quiz-container');
        const resultsContainer = document.getElementById('results-container');
        const currentQNumEl = document.getElementById('current-q-num');
        const totalQNumEl = document.getElementById('total-q-num');
        const progressBar = document.getElementById('progress-bar');
        const questionTextEl = document.getElementById('question-text');
        const questionImageEl = document.getElementById('question-image');
        const optionsContainer = document.getElementById('options-container');
        const nextBtn = document.getElementById('next-btn');
        const feedbackMessageEl = document.getElementById('feedback-message');
        const scoreValEl = document.getElementById('score-val');
        const scoreTotalEl = document.getElementById('score-total');
        const resultsFeedbackEl = document.getElementById('results-feedback');
        const restartBtn = document.getElementById('restart-btn');

        // Utils
        function shuffleArray(array) {
            const newArray = [...array];
            for (let i = newArray.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [newArray[i], newArray[j]] = [newArray[j], newArray[i]];
            }
            return newArray;
        }

        // Initialize
        function initQuiz() {
            if (!quizData || !quizData.questions || quizData.questions.length === 0) {
                quizContainer.innerHTML = '<p style="text-align:center">Không có câu hỏi nào.</p>';
                return;
            }
            
            titleEl.textContent = quizData.title || 'Bài trắc nghiệm';
            
            // Apply settings
            questions = [...quizData.questions];
            if (quizData.settings && quizData.settings.shuffleQuestions) {
                questions = shuffleArray(questions);
            }
            
            totalQNumEl.textContent = questions.length;
            scoreTotalEl.textContent = questions.length;
            
            restartBtn.addEventListener('click', restartQuiz);
            nextBtn.addEventListener('click', handleNext);
            
            loadQuestion();
        }

        function loadQuestion() {
            const question = questions[currentQuestionIndex];
            isAnswered = false;
            hasAttempted = false;
            
            currentQNumEl.textContent = currentQuestionIndex + 1;
            progressBar.style.width = `${(currentQuestionIndex / questions.length) * 100}%`;
            
            questionTextEl.textContent = question.text;
            
            if (question.image) {
                questionImageEl.src = question.image;
                questionImageEl.classList.remove('hidden');
            } else {
                questionImageEl.classList.add('hidden');
            }
            
            optionsContainer.innerHTML = '';
            feedbackMessageEl.className = 'feedback-message hidden';
            
            let answers = [...question.answers];
            if (quizData.settings && quizData.settings.shuffleAnswers) {
                answers = shuffleArray(answers);
            }
            
            answers.forEach((answer, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                
                if (answer.image) {
                    const img = document.createElement('img');
                    img.src = answer.image;
                    img.className = 'option-image';
                    btn.appendChild(img);
                }
                
                const textSpan = document.createElement('span');
                textSpan.innerHTML = `<strong>${String.fromCharCode(65 + index)}.</strong> ${answer.text}`;
                btn.appendChild(textSpan);
                
                btn.addEventListener('click', () => handleSelect(answer.isCorrect, btn, answers));
                optionsContainer.appendChild(btn);
            });
            
            nextBtn.classList.add('hidden');
        }

        function handleSelect(isCorrect, selectedBtn, answers) {
            if (isAnswered) return;
            
            if (isCorrect) {
                isAnswered = true;
                if (!hasAttempted) {
                    score++;
                }
                correctSound.currentTime = 0;
                correctSound.play().catch(e => console.log('Audio play failed', e));
                
                selectedBtn.classList.add('correct');
                
                const buttons = optionsContainer.querySelectorAll('.option-btn');
                buttons.forEach(btn => btn.disabled = true);
                
                feedbackMessageEl.textContent = 'Chính xác! Giỏi lắm!';
                feedbackMessageEl.className = 'feedback-message feedback-correct';
                
                nextBtn.classList.remove('hidden');
                if (currentQuestionIndex === questions.length - 1) {
                    nextBtn.textContent = 'Xem kết quả';
                } else {
                    nextBtn.textContent = 'Tiếp tục';
                }
            } else {
                hasAttempted = true;
                incorrectSound.currentTime = 0;
                incorrectSound.play().catch(e => console.log('Audio play failed', e));
                
                selectedBtn.classList.add('incorrect');
                selectedBtn.disabled = true;
                
                feedbackMessageEl.textContent = 'Chưa đúng, hãy chọn lại đáp án khác nhé!';
                feedbackMessageEl.className = 'feedback-message feedback-incorrect';
            }
        }

        function handleNext() {
            if (currentQuestionIndex < questions.length - 1) {
                currentQuestionIndex++;
                loadQuestion();
            } else {
                showResults();
            }
        }

        function showResults() {
            quizContainer.classList.add('hidden');
            resultsContainer.classList.remove('hidden');
            
            scoreValEl.textContent = score;
            
            const percentage = (score / questions.length) * 100;
            if (percentage === 100) {
                resultsFeedbackEl.textContent = 'Xuất sắc! Bạn đã trả lời đúng tất cả các câu hỏi.';
            } else if (percentage >= 70) {
                resultsFeedbackEl.textContent = 'Rất tốt! Bạn đã nắm vững kiến thức.';
            } else if (percentage >= 50) {
                resultsFeedbackEl.textContent = 'Khá tốt! Hãy cố gắng hơn ở những lần sau.';
            } else {
                resultsFeedbackEl.textContent = 'Cần cố gắng hơn! Hãy ôn tập lại kiến thức nhé.';
            }
            
            victorySound.currentTime = 0;
            victorySound.play().catch(e => console.log('Audio play failed', e));
            
            // Trigger confetti
            if (typeof confetti === 'function') {
                const duration = 3000;
                const end = Date.now() + duration;

                (function frame() {
                    confetti({
                        particleCount: 5,
                        angle: 60,
                        spread: 55,
                        origin: { x: 0 },
                        colors: ['#4f46e5', '#22c55e', '#eab308', '#ec4899']
                    });
                    confetti({
                        particleCount: 5,
                        angle: 120,
                        spread: 55,
                        origin: { x: 1 },
                        colors: ['#4f46e5', '#22c55e', '#eab308', '#ec4899']
                    });

                    if (Date.now() < end) {
                        requestAnimationFrame(frame);
                    }
                }());
            }
        }

        function restartQuiz() {
            currentQuestionIndex = 0;
            score = 0;
            resultsContainer.classList.add('hidden');
            quizContainer.classList.remove('hidden');
            
            // Re-shuffle if needed
            if (quizData.settings && quizData.settings.shuffleQuestions) {
                questions = shuffleArray([...quizData.questions]);
            }
            
            loadQuestion();
        }

        // Start
        initQuiz();
    </script>
</body>
</html>
